{
    "autoDocstring.customTemplatePath": "/Users/anhoang/.vscode/docstring.template",
    "autoDocstring.docstringFormat": "google",
    "debug.onTaskErrors": "showErrors",
    "editor.codeActionsOnSave": {
        "source.organizeImports": true
    },
    "editor.fontFamily": "'Hack Nerd Font Mono', Monaco, 'Courier New', monospace",
    "editor.fontSize": 13,
    "editor.formatOnPaste": false,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.renderLineHighlight": "all",
    "editor.minimap.enabled": false,
    "editor.rulers": [
        100
    ],
    "editor.suggestSelection": "first",
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "git.autofetch": true,
    "pylance.insidersChannel": "daily",
    "python.analysis.typeCheckingMode": "basic",
    "python.condaPath": "$HOME/anaconda3/bin/conda",
    "python.formatting.blackArgs": [
        "--line-length=100"
    ],
    "python.formatting.provider": "black",
    "python.languageServer": "Pylance",
    "python.linting.flake8Args": [
        "--max-line-length=100",
        "--docstring-convention=google"
    ],
    "python.linting.flake8Enabled": true,
    "python.linting.mypyArgs": [
        "--ignore-missing-imports",
        "--follow-imports=silent",
        "--disallow-untyped-defs",
        "--disallow-incomplete-defs",
        "--disallow-untyped-calls",
        "--warn-unused-ignores",
        "--show-column-numbers",
        "--show-error-codes"
    ],
    "python.linting.mypyEnabled": true,
    "python.pythonPath": "/Users/anhoang/.pyenv/versions/3.8.9/bin/python",
    "python.sortImports.args": [
        "--line-length=100",
        "--profile=black",
        "--atomic"
    ],
    "python.sortImports.path": "${workspaceFolder}/.venv/bin/isort",
    "terminal.integrated.inheritEnv": false,
    "terminal.integrated.lineHeight": 1.2,
    "vim.enableNeovim": true,
    "vim.foldfix": true,
    "vim.highlightedyank.enable": true,
    "vim.hlsearch": true,
    "vim.neovimPath": "/usr/local/bin/nvim",
    "vim.normalModeKeyBindings": [
        {
            "after": [
                "g",
                "b"
            ],
            "before": [
                "<c-n>"
            ]
        },
        {
            "after": [
                "?",
                "d",
                "e",
                "f",
                "\\",
                "s",
                "+",
                "[",
                "_",
                "\\",
                "w",
                "]",
                "+",
                "\\",
                "(",
                ".",
                "*",
                "\\",
                ")",
                ".",
                "*",
                ":",
                "<cr>",
            ],
            "before": [
                "g",
                "m"
            ]
        },
        {
            "after": [
                "?",
                "c",
                "l",
                "a",
                "s",
                "s",
                "\\",
                "s",
                "+",
                "[",
                "_",
                "\\",
                "w",
                "]",
                "+",
                "<cr>",
            ],
            "before": [
                "g",
                "c"
            ]
        },
        {
            "before": [
                "g",
                "r"
            ],
            "commands": [
                "editor.action.goToReferences"
            ]
        },
        {
            "before": [
                "g",
                "n"
            ],
            "commands": [
                "editor.action.dirtydiff.next",
                "workbench.action.compareEditor.nextChange",
            ]
        },
        {
            "before": [
                "g",
                "x",
            ],
            "commands": [
                "git.openChange",
            ]
        },
        {
            "before": [
                "g",
                "p"
            ],
            "commands": [
                "editor.action.dirtydiff.previous",
                "workbench.action.compareEditor.previousChange",
            ]
        },
        {
            "before": [
                "K"
            ],
            "commands": [
                "editor.action.showHover"
            ]
        }
    ],
    "vim.smartRelativeLine": true,
    "vim.useSystemClipboard": true,
    "vim.visualstar": true,
    "vim.visualModeKeyBindings": [
        {
            "after": [
                "g",
                "b"
            ],
            "before": [
                "<c-n>"
            ]
        },
        {
            "before": [
                "g",
                "r",
            ],
            "commands": [
                "git.revertSelectedRanges",
            ]
        },
        {
            "before": [
                "g",
                "s",
            ],
            "commands": [
                "git.stageSelectedRanges",
            ]
        },
        {
            "before": [
                "g",
                "u",
            ],
            "commands": [
                "git.unstageSelectedRanges",
            ]
        },
        {
            "before": [
                "<c-i>"
            ],
            "commands": [
                "jupyter.execSelectionInteractive"
            ]
        }
    ],
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "window.autoDetectColorScheme": true,
    "workbench.editor.showTabs": true,
    "workbench.editorAssociations": [
        {
            "filenamePattern": "*.ipynb",
            "viewType": "jupyter.notebook.ipynb"
        }
    ],
    "workbench.startupEditor": "newUntitledFile",
    "jupyter.alwaysTrustNotebooks": true,
    "workbench.colorTheme": "GitHub Light Default",
    "window.zoomLevel": 1,
    "diffEditor.ignoreTrimWhitespace": false,
    "workbench.preferredLightColorTheme": "GitHub Light Default",
    "workbench.preferredHighContrastColorTheme": "GitHub Dark Default",
    "workbench.preferredDarkColorTheme": "GitHub Dark Default",
    "vim.statusBarColorControl": true,
    "workbench.colorCustomizations": {
        "statusBar.background": "#bef5cb",
        "statusBar.noFolderBackground": "#bef5cb",
        "statusBar.debuggingBackground": "#bef5cb"
    },
    "vim.statusBarColors.commandlineinprogress": "#fdaeb7",
    "vim.statusBarColors.insert": "#bef5cb",
    "vim.statusBarColors.normal": "#c8e1ff",
    "vim.statusBarColors.replace": "#d1bcf9",
    "vim.statusBarColors.visual": "#d1bcf9",
    "vim.statusBarColors.visualblock": "#d1bcf9",
    "vim.statusBarColors.visualline": "#d1bcf9",
    "vim.statusBarColors.searchinprogressmode": "#fff5b1",
    "vim.statusBarColors.surroundinputmode": "#fdaeb7",
    "vim.statusBarColors.easymotionmode": "#fdaeb7",
    "vim.statusBarColors.easymotioninputmode": "#fdaeb7"
}